# ─────────────────────────────────────────────────────────────
# Autocontrol — variables de entorno
# Copiá este archivo a .env y completá los valores.
# En Coolify, cargá estas mismas variables en la sección Environment.
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
# Local (docker-compose):
DATABASE_URL="postgresql://autocontrol:autocontrol@localhost:5432/autocontrol?schema=public"
# En Coolify usá el host interno del servicio Postgres, por ejemplo:
# DATABASE_URL="postgresql://USUARIO:PASSWORD@nombre-servicio-postgres:5432/autocontrol?schema=public"

# Auth.js (NextAuth v5)
# Generá un secreto con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# URL pública de la app (en Coolify, tu dominio). En local:
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Super admin inicial (se crea si SEED_ON_START=true en el primer deploy).
# Por defecto se siembra SOLO esta cuenta (sin datos demo).
SUPER_ADMIN_EMAIL="tu-email@dominio.com"
SUPER_ADMIN_PASSWORD=""          # opcional; si queda vacío usa "autocontrol123"
# SEED_ON_START="true"           # solo el PRIMER deploy: crea el super admin
# SEED_DEMO="true"               # opcional: además carga talleres/órdenes demo

# Email (notificaciones in-app + email). SMTP genérico.
# Para desarrollo podés usar un servicio como Mailtrap, o dejarlo vacío
# (los emails se loguean en consola en lugar de enviarse).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Autocontrol <no-reply@autocontrol.app>"

# Recordatorios de turnos (cron). Generá un secreto y configurá un cron horario
# que pegue a:  GET /api/cron/recordatorios?token=EL_SECRETO
CRON_SECRET=""
